# AI Taiwan Equity Research Platform — Environment Variables
# Copy this file to .env and fill in your credentials

# ─── Required ───────────────────────────────────────────────

# Anthropic Claude API (for Explainable AI)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Recommended ────────────────────────────────────────────

# FinMind API token (for financial data: EPS, ROE, ROA, etc.)
# Register free at: https://finmind.github.io/
FINMIND_TOKEN=your_finmind_token_here

# ─── Optional notifications ──────────────────────────────────

# Email (Gmail)
# EMAIL_SENDER=your_gmail@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_RECIPIENT=recipient@email.com

# Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
